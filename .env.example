# PostgreSQL
POSTGRES_USER=airafin
POSTGRES_PASSWORD=airafin
POSTGRES_DB=airafin

# Shared secret for POST /api/transactions (Telegram bot in Phase 2)
API_SECRET_TOKEN=change-me-in-production

# Frontend (local dev / Docker)
ORIGIN=http://localhost:3080
API_URL=http://localhost:3081
# Dashboard sign-in password (required for web UI)
DASHBOARD_PASSWORD=Aira2026Fin!
# Optional: cookie signing secret for dashboard login session
SESSION_SECRET=change-me-in-production

# Google Sheets dual-write (optional — omit to use PostgreSQL only)
GOOGLE_SHEETS_SPREADSHEET_ID=
# Docker: path inside container (mount backend/secrets/ → /app/secrets)
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/service-account.json
