# Host nginx — separate from teknodika.com (own server_name + SSL cert).
# Docker only runs db + backend + frontend on 127.0.0.1:3080 / :3081.
#
# IMPORTANT: proxy ALL traffic to the frontend (3080) only.
# Do NOT add a separate `location /api/` → backend:3081 block — that strips /api
# and causes 404 "Route GET:/dashboard/summary not found".
#
# Setup on VPS (once):
#   1. DNS: airafin.teknodika.com → VPS IP
#   2. sudo cp deploy/nginx-airafin.conf.example /etc/nginx/sites-available/airafin
#   3. sudo ln -s /etc/nginx/sites-available/airafin /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d airafin.teknodika.com
#
# Deploy app: bash deploy/docker-deploy.sh
#
# Optional: redirect IP:3080 → airafin domain (replace VPS_PUBLIC_IP).
# Does NOT touch port 80/443 on the bare IP (teknodika / default server keeps those).

server {
    listen 3080;
    listen [::]:3080;
    server_name VPS_PUBLIC_IP;

    return 301 https://airafin.teknodika.com$request_uri;
}

server {
    listen 80;
    server_name airafin.teknodika.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name airafin.teknodika.com;

    # certbot adds ssl_certificate / ssl_certificate_key here

    location / {
        proxy_pass http://127.0.0.1:3080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
