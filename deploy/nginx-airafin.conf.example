# Optional: use this if the VPS already runs nginx on ports 80/443.
# Do NOT run the caddy service in docker-compose when using host nginx.
#
# 1. DNS: airafin.teknodika.com → your VPS IP
# 2. sudo certbot --nginx -d airafin.teknodika.com
# 3. Include this in sites-enabled and reload nginx

server {
    listen 80;
    server_name airafin.teknodika.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name airafin.teknodika.com;

    # certbot fills these paths:
    # ssl_certificate /etc/letsencrypt/live/airafin.teknodika.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/airafin.teknodika.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
