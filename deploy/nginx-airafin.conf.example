# Host nginx — separate from teknodika.com (own server_name + SSL cert).
# Docker only runs db + backend + frontend on 127.0.0.1:3080 / :3081.
#
# Setup on VPS (once):
#   1. DNS: airafin.teknodika.com → VPS IP
#   2. sudo cp deploy/nginx-airafin.conf.example /etc/nginx/sites-available/airafin
#   3. sudo ln -s /etc/nginx/sites-available/airafin /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d airafin.teknodika.com
#      (separate certificate from teknodika.com — certbot adds ssl_* lines below)
#
# Deploy app: bash deploy/docker-deploy.sh (no nginx in Docker)

server {
    listen 80;
    server_name airafin.teknodika.com;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name airafin.teknodika.com;

    # Added by certbot (paths differ from teknodika.com):
    # ssl_certificate /etc/letsencrypt/live/airafin.teknodika.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/airafin.teknodika.com/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:3080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
